---
import Layout from '../Base.astro';
import Testimonials from '../components/Testimonials.astro';
import { buildFaqSchema } from '../lib/schema';

const schema = [
  {
    '@type': 'ContactPage',
    name: 'Contact Kelp',
    description: 'Get in touch with Kelp Creative Agency to discuss branding, websites, and marketing support.',
  },
  {
    '@type': 'ProfessionalService',
    name: 'Kelp Creative Agency',
    url: 'https://www.kelp.agency/contact/',
    telephone: '+1-352-325-7688',
    email: 'info@kelp.agency',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Brooksville',
      addressRegion: 'FL',
      postalCode: '34605',
      postOfficeBoxNumber: '116',
      addressCountry: 'US',
    },
    areaServed: {
      '@type': 'State',
      name: 'Florida',
    },
  },
  buildFaqSchema([
    {
      question: 'How do I contact Kelp Creative Agency?',
      answer: 'You can book a meeting on the contact page or call Kelp at 352-325-7688.',
    },
    {
      question: 'Where is Kelp Creative Agency located?',
      answer: 'Kelp Creative Agency is based in Brooksville, Florida and works with businesses across Florida and beyond.',
    },
  ]),
];
---

<Layout title="Contact Kelp" darkHeader={true} schema={schema}>
	<article>
		<section class="contact-section">
			<div class="wrapper">
				<div class="contact-section-column" data-lg-reveal="fade" data-lg-reveal-stagger=".2">
					<h1>Well hello there.</h1>
					<hr />
					<p data-lg-reveal="fade" data-lg-reveal-delay=".25">
						Interested in our services? Setup a chat with Andrew. He’d love to talk with you and see how Kelp can be of
						help.
					</p>

					<h2>Other ways to reach us.</h2>
					<h3 class="h6">Office Address</h3>
					<address>P.O. Box 116<br /> Brooksville, FL 34605</address>
					<p><i>New Office Coming Soon</i></p>
					<p>Phone: <a href="tel:+1-352-325-7688">352-325-7688</a></p>
				</div>
				<div class="contact-section-column" data-lg-reveal="layer-to-right" data-lg-reveal-delay=".5">
					<div id="meetings-embed">
						<div class="meetings-iframe-container" data-src="https://store.kelp.agency/meetings/andrew1417?embed=true">
						</div>
					</div>
				</div>
			</div>
		</section>
		<Testimonials />
	</article>
</Layout>

<style lang="scss">
	// contact page
	.contact-section {
		background: var(--black);
		color: white;
		padding-top: 4rem;
		a {
			color: var(--green);
		}
		.wrapper {
			display: flex;
			flex-wrap: wrap;
			gap: 3rem;
		}
		&-column {
			flex: 1 1 500px;
			margin-bottom: 4rem;
			h1 {
				margin-bottom: 2rem;
			}
			h2 {
				margin-top: 4rem;
				margin-bottom: 2rem;
			}
			&:first-child {
				flex-basis: 250px;
			}
		}
		#meetings-embed {
			height: 756px;
		}
	}
</style>

<script>
	const HUBSPOT_MEETINGS_SCRIPT_SRC = 'https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js';

	const setEmbedIframeTitle = (embedRoot: HTMLElement) => {
		embedRoot.querySelectorAll('iframe').forEach((iframe) => {
			iframe.title = 'Schedule a meeting with Kelp Creative Agency';
			iframe.loading = 'lazy';
		});
	};

	const initMeetingsEmbed = () => {
		const embedRoot = document.querySelector('#meetings-embed');
		const container = embedRoot?.querySelector('.meetings-iframe-container');
		if (!(embedRoot instanceof HTMLElement) || !(container instanceof HTMLDivElement)) {
			return;
		}

		embedRoot.querySelectorAll('iframe').forEach((iframe) => iframe.remove());
		container.replaceChildren();

		document.querySelectorAll('script[data-hubspot-meetings-embed]').forEach((script) => script.remove());

		const script = document.createElement('script');
		script.src = HUBSPOT_MEETINGS_SCRIPT_SRC;
		script.async = true;
		script.defer = true;
		script.dataset.hubspotMeetingsEmbed = 'true';
		document.body.appendChild(script);

		const observer = new MutationObserver(() => {
			setEmbedIframeTitle(embedRoot);
		});
		observer.observe(embedRoot, {
			childList: true,
			subtree: true,
		});

		setEmbedIframeTitle(embedRoot);
	};

	const initMeetingsEmbedWhenVisible = () => {
		const embedRoot = document.querySelector('#meetings-embed');
		if (!(embedRoot instanceof HTMLElement)) {
			return;
		}

		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) {
						return;
					}

					initMeetingsEmbed();
					observer.disconnect();
				});
			}, { rootMargin: '200px' });

			observer.observe(embedRoot);
		} else {
			initMeetingsEmbed();
		}
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initMeetingsEmbedWhenVisible, { once: true });
	} else {
		initMeetingsEmbedWhenVisible();
	}
</script>
