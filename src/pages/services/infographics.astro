---
import Layout from '../../Base.astro';
import SimpleHero from '../../components/SimpleHero.astro';
import { Picture } from 'astro:assets';
import batteryInfographic from '../../assets/images/infographics/battery-upkeep-infographic.png';
import boostInfographic from '../../assets/images/infographics/boost-infographic.jpg';
import flashlightSafetyInfographic from '../../assets/images/infographics/flashlight-safety-infographic.jpg';
import flashlightsInfographic from '../../assets/images/infographics/flashlights-infographic.jpg';
import labelPrinterInfographic from '../../assets/images/infographics/label-printer-infographic.gif';
import safetyTipsInfographic from '../../assets/images/infographics/safety-tips-infographic.jpg';
import FeaturedArticles from '../../components/FeaturedArticles.astro';
import ServicesRelatedWork from '../../components/ServicesRelatedWork.astro';
import '../../styles/pages/_services-list.scss';
---

<Layout
  title="Infographics | Florida Graphic Design Agency"
  description="When the information is valuable but hard to absorb, people tune out. We turn dense ideas, processes, and data into infographics that are easier to follow and easier to share."
>
  <SimpleHero
    tagline="Content Creation Services"
    title="Infographics"
    description="When the information is valuable but hard to absorb, people tune out. We turn dense ideas, processes, and data into infographics that are easier to follow and easier to share."
    lottieFile="infographics.json"
  />
  <div class="wrapper infographics">
    <div class="infographics-grid" data-lg-reveal="layer-to-right" data-lg-reveal-stagger="0.1">
      <h2>We Make<br /> Infographics Like...</h2>
      <Picture
        src={batteryInfographic}
        loading="lazy"
        alt="battery upkeep infographic"
        width={1700}
        height={5662}
        widths={[480, 900, 1700]}
        sizes="(max-width: 900px) 100vw, 50vw"
        inferSize
      />
      <Picture
        src={boostInfographic}
        loading="lazy"
        alt="marketing infographic"
        width={750}
        height={5945}
        widths={[360, 600, 750]}
        sizes="(max-width: 900px) 100vw, 50vw"
        inferSize
      />
      <Picture
        src={flashlightSafetyInfographic}
        loading="lazy"
        alt="flashlight safety infographic"
        width={600}
        height={1831}
        widths={[320, 480, 600]}
        sizes="(max-width: 900px) 100vw, 50vw"
        inferSize
      />
      <Picture
        src={flashlightsInfographic}
        loading="lazy"
        alt="flashlights infographic"
        width={800}
        height={5020}
        widths={[400, 650, 800]}
        sizes="(max-width: 900px) 100vw, 50vw"
        inferSize
      />
      <Picture
        src={labelPrinterInfographic}
        loading="lazy"
        alt="marketing infographic"
        width={600}
        height={1114}
        widths={[320, 480, 600]}
        sizes="(max-width: 900px) 100vw, 50vw"
        inferSize
      />
      <Picture
        src={safetyTipsInfographic}
        loading="lazy"
        alt="safety tips infographic"
        width={600}
        height={3591}
        widths={[320, 480, 600]}
        sizes="(max-width: 900px) 100vw, 50vw"
        inferSize
      />
    </div>
  </div>
  <div class="service-body">
    <div class="wrapper wrapper--narrow">
      <h2>Where teams get stuck</h2>
      <p>
        Sometimes the information is strong, but the format is doing it no favors. Research, process explanations,
        educational content, and campaign messaging can become too dense for people to finish or remember.
      </p>
      <p>When the audience has to work too hard to understand the story, the message gets lost before the value lands.</p>
      <h2>How we fix it</h2>
      <p>We turn complex information into a clearer visual sequence, balancing copy, hierarchy, and design so people can understand the main point quickly and keep following the story.</p>
      <ul>
        <li>Informational design</li>
        <li>Process visualization</li>
        <li>Explainers</li>
        <li>Flowcharts</li>
        <li>Tutorials</li>
        <li>Microcontent</li>
        <li>Social</li>
      </ul>
      <h2>What moving forward looks like</h2>
      <p>
        If you have research, internal knowledge, or campaign material that needs to become clearer fast, we can help
        shape it into a visual story people are far more likely to finish and share.
      </p>
      <p><a href="/contact/" class="button button--green">Turn Your Info Into a Visual Story</a></p>
    </div>
    <ServicesRelatedWork tag={85} />
  </div>
  <FeaturedArticles />
</Layout>

<style lang="scss" is:global>
  .infographics {
    margin-bottom: 6rem;
    max-width: 1200px;
    h2 {
      margin-bottom: 2rem;
    }
    &-grid {
      column-count: 2;
      column-gap: 2rem;
      picture {
        margin-bottom: 2rem;
      }
    }
  }
</style>
