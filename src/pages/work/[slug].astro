---
import Layout from '../../Base.astro';
import FeaturedArticles from '../../components/FeaturedArticles.astro';
import '../../styles/pages/_wordpress.scss';
import { getAverageColor } from 'fast-average-color-node';
import { Picture } from 'astro:assets';
import { sanitizeHtml } from '../../lib/sanitize';
import { toJetpackImageUrl } from '../../lib/jetpack';
import { fetchWpJson } from '../../lib/wp';

export async function getStaticPaths() {
  const posts = await fetchWpJson('/work?per_page=100&_embed', [] as Record<string, any>[]);

  return posts.map((post) => {
    return {
      params: { slug: post.slug },
      props: {
        title: post.title.rendered,
        description: post.excerpt.rendered.replace(/(<([^>]+)>)/gi, ''),
        image: [post.fimg_url],
        content: post.content.rendered,
        tagIds: post.tags,
        id: post.id,
        acf: post.acf,
        datePublished: post.date,
        dateModified: post.modified,
      },
    };
  });
}

const { title, content, description, image, tagIds, id, acf, datePublished, dateModified } = Astro.props;

const rawTitle = title.replace(/(<([^>]+)>)/gi, '').trim();
const titleWords = rawTitle.split(/\s+/);

const formattedTitle =
  titleWords.length > 1
    ? titleWords.map((word: string) => `<span class="work-post-hero-title-word">${word}</span>`).join(' ')
    : rawTitle;

const now = new Date();
const modifiedDate = dateModified ? new Date(dateModified) : null;
const safeDateModified = modifiedDate && modifiedDate > now ? datePublished : dateModified || datePublished;
const cleanDescription = description.replace(/(<([^>]+)>)/gi, '').trim();
const schema = {
  '@type': 'CreativeWork',
  headline: rawTitle,
  description: cleanDescription,
  datePublished,
  dateModified: safeDateModified,
  image: image?.length ? image : undefined,
  publisher: {
    '@id': 'https://www.kelp.agency/#organization',
  },
  mainEntityOfPage: {
    '@id': `${Astro.url.href}#webpage`,
  },
};

let bgUrl = null;
let thumbUrl = null;
let bgOriginalUrl = null;

// hero image (ACF hero.background.image)
if (acf?.hero?.background?.image) {
  const media = await fetchWpJson(`/media/${acf.hero.background.image}`, null as Record<string, any> | null);
  const original = media?.source_url || null;
  bgOriginalUrl = original;
  bgUrl = toJetpackImageUrl(original);
  thumbUrl = toJetpackImageUrl(
    media?.media_details?.sizes?.medium?.source_url || media?.media_details?.sizes?.thumbnail?.source_url || original,
  );
}

let isDarkHero = false;

// brightness detection
if (thumbUrl) {
  try {
    const result = await getAverageColor(thumbUrl);
    const [r, g, b] = result.value;
    const brightness = 0.2126 * r + 0.7152 * g + 0.0722 * b;
    isDarkHero = brightness < 165;
  } catch (e) {
    console.warn('Brightness detection failed', e);
  }
}

const accent = acf?.site_frame_color ? acf.site_frame_color : 'transparent';
const safeContent = sanitizeHtml(content);
---

<Layout
  title={title}
  description={description}
  image={image?.[0]}
  darkHeader={true}
  schema={schema}
  ogType="article"
  articlePublished={datePublished}
  articleModified={safeDateModified}
>
  <article class="work-post" style=`--accent: ${accent};`>
    <div class={`work-post-hero ${isDarkHero ? 'is-dark' : ''}`}>
      {
        bgUrl && (
          <Picture
            src={bgOriginalUrl || bgUrl}
            alt={title}
            width="1920"
            height="1080"
            widths={[768, 1200, 1600, 1920]}
            sizes="100vw"
            priority
            class="work-post-hero-img"
            inferSize
          />
        )
      }
      <div class="wrapper">
        <h1 transition:name={`heading-${id}`} set:html={formattedTitle} />
      </div>
    </div>

    <div class="wrapper work-post-body" data-lg-reveal="fade" data-lg-reveal-stagger="0.3" set:html={safeContent} />
  </article>

  <FeaturedArticles tag={tagIds} heading="Related Articles" />
</Layout>

<style lang="scss" is:global>
  .work-post {
    margin-bottom: 6rem;

    &-hero {
      position: relative;
      padding: 0;
      margin-bottom: -8rem;

      &-img {
        display: block;
        width: 100%;
        height: 100%;
        position: absolute;
        inset: 0;
        :global(img) {
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: top center;
        }
      }

      .wrapper {
        padding: 8rem 0 16rem;
        position: relative;
      }

      h1 {
        margin: 0 4rem;
        font-size: var(--step-8);
        line-height: 0.833;

        @media (max-width: 767px) {
          margin: 0;
        }

        span:last-child {
          display: block;
        }

        &::after {
          content: '';
          display: block;
          width: 200px;
          background: var(--accent);
          height: 0.5rem;
          margin-top: 0;
        }
      }
    }

    &-hero.is-dark {
      background-color: var(--black);

      h1 {
        color: #fff;
        text-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
      }
    }

    &-body {
      h2 {
        font-size: var(--step-3);
      }

      h3,
      .h3 {
        font-size: var(--step-2);
      }

      blockquote {
        background: #f4f4f4;

        @media (min-width: 961px) {
          padding: 12rem 8rem 11rem;
        }

        @media (max-width: 767px) {
          padding: 2rem;
        }

        p {
          @media (max-width: 767px) {
            font-size: 18px;
          }
        }

        cite {
          display: block;

          @media (max-width: 767px) {
            font-size: 16px;
          }

          &::before {
            margin-top: 2.5rem;
            margin-bottom: 2.5rem;

            @media (max-width: 767px) {
              margin-top: 1.5rem;
              margin-bottom: 1.5rem;
            }
          }
        }

        &::before,
        &::after {
          color: var(--green);
        }

        &::after {
          @media (max-width: 767px) {
            display: none;
          }
        }
      }
    }

    .tiled-gallery {
      &__col {
        @media (max-width: 767px) {
          flex: 1 1 100%;
        }
      }

      &__row {
        display: flex;
        margin: 4rem 0;
        gap: 2rem;

        @media (max-width: 767px) {
          flex-wrap: wrap;
        }

        figure {
          margin: 0;
        }
      }
    }

    .wp-block-media-text__media {
      padding: 1.5rem 1.5rem 0.5rem 1.5rem;

      @media (min-width: 768px) {
        padding: 4rem;
      }
    }

    .wp-element-caption {
      text-align: center;
    }

    .has-white-color {
      color: white;
    }

    .has-black-background-color {
      background: var(--black);
    }

    .footer {
      margin-top: 10rem;
    }
  }
</style>

<script>
  const updateEmbeddedIframes = () => {
    document.querySelectorAll<HTMLIFrameElement>('iframe[width][height]').forEach((el) => {
      const w = parseFloat(el.getAttribute('width') ?? '0');
      const h = parseFloat(el.getAttribute('height') ?? '0');

      if (w > 0 && h > 0) {
        el.style.aspectRatio = `${w} / ${h}`;
        el.style.width = '100%';
        el.style.height = 'auto';
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateEmbeddedIframes, { once: true });
  } else {
    updateEmbeddedIframes();
  }
</script>
