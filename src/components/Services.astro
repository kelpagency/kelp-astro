        data-lg-lottie-autoplay="true"
        data-lg-lottie-loop="true"
        data-lg-lottie-lazy="true"
      >
      </div>
      <h3 data-lg-parallax>Media</h3>
    </div>
    <div class="service-right">
      <p>
        Strong media gives people something concrete to see, hear, and remember. We create visual content that helps
        brands explain, persuade, and stay consistent across channels.
      </p>
      <ul data-lg-reveal data-lg-reveal-stagger="0.1">
        <li data-lg-reveal="layer-to-right">
          <a href="/services/motion-graphics/">Motion Graphics</a>
        </li>
        <li data-lg-reveal="layer-to-right">
          <a href="/services/photography/">Photography</a>
        </li>
        <li data-lg-reveal="layer-to-right">
          <a href="/services/video/">Videography</a>
        </li>
      </ul>
    </div>
  </div>
  <div class="service service--ongoing" id="support">
    <div class="service-left">
      <div data-lg-parallax data-lg-parallax-amplitude="0.3">
        <div class="service-square" data-lg-reveal="layer-to-right"></div>
      </div>
      <div
        class="service-icon"
        data-lg-reveal="fade"
        data-lg-reveal-delay=".02"
        data-lg-parallax
        data-lg-parallax-amplitude="0.4"
        data-lg-lottie="/animations/ongoing-support.json"
        data-lg-lottie-autoplay="true"
        data-lg-lottie-loop="true"
        data-lg-lottie-lazy="true"
      >
      </div>
      <h3 data-lg-parallax>Ongoing Support</h3>
    </div>
    <div class="service-right">
      <p>
        Some teams do not need one more one-off project. They need reliable support after launch, on a monthly basis,
        so the work keeps moving without rebuilding momentum every time.
      </p>
      <ul data-lg-reveal data-lg-reveal-stagger="0.1">
        <li data-lg-reveal="layer-to-right">
          <a href="/services/ongoing-retainers/">Ongoing Retainers</a>
        </li>
        <li data-lg-reveal="layer-to-right">
          <a href="/services/web-hosting/">Web Hosting</a>
        </li>
        <li data-lg-reveal="layer-to-right">
          <a href="/services/website-support/">Web Support & Maintenance</a>
        </li>
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  .service {
    margin: 10rem auto 8rem;
    display: flex;
    gap: 1rem 5rem;
    flex-wrap: wrap;
    max-width: 1100px;
    scroll-margin-top: 200px;
    @media (min-width: 768px) {
      padding-left: 70px;
      padding-right: 70px;
    }
    &s {
      padding: 6rem 0;
      @media (max-width: 767px) {
        padding: 3rem 0 5rem;
      }
    }
    &-square {
      width: 108px;
      height: 108px;
      display: block;
      position: absolute;
      right: 0;
      z-index: -1;
      top: 2rem;
      background: var(--light-teal);
      .service--marketing & {
        background: var(--light-green);
        right: 1rem;
      }
      .service--ongoing & {
        background: var(--light-red);
      }
    }
    &-icon {
      width: 140px;
      margin-right: -1rem;
      margin-left: auto;
    }
    &-left {
      flex: 1 1 250px;
      position: relative;
      text-align: right;
      margin-top: -5rem;
      max-width: 300px;
      h3 {
        text-align: left;
        margin: 0;
        font-weight: bold;
      }
    }
    &-right {
      flex: 1 1 400px;
      .lg-reveal--layer-to-right:after {
        background-color: var(--light-teal);
      }
      .service--marketing & {
        .lg-reveal--layer-to-right:after {
          background-color: var(--light-green);
        }
      }
      .service--ongoing & {
        .lg-reveal--layer-to-right:after {
          background-color: var(--light-red);
        }
      }
      ul {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        list-style: none;
        padding: 0;
        margin-top: 2rem;
        li {
          line-height: 1.2;
          font-weight: bold;
        }
      }
    }
  }
</style>
